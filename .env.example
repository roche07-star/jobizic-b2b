# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google Custom Search API (for LinkedIn searching)
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# Site URL (Auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App URL (텔레그램 "웹에서 보기" 버튼 등, 프로덕션: https://jobizic-biz.vercel.app/)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Telegram Bot (Optional)
# BotFather에서 봇 생성 후 발급받은 토큰
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# 봇의 username (예: jobizic_recruiter_bot)
TELEGRAM_BOT_USERNAME=your_bot_username
# Webhook 보안 토큰 (랜덤 문자열, 자동 생성 가능)
TELEGRAM_SECRET_TOKEN=your_random_secret_token
